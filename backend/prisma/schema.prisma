generator client {
  provider = "prisma-client"
  output   = "./generated/client"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Category {
  SPORTS
  GO_KARTING
  CRICKET
  FOOTBALL
  GAMING
  FOOD
  OUTDOOR
  MUSIC
  SOCIAL
  FITNESS
  TRAVEL
}

enum HangoutStatus {
  OPEN
  FULL
  CANCELLED
  COMPLETED
}

enum JoinStatus {
  PENDING
  ACCEPTED
  DECLINED
}

// ─── Models ──────────────────────────────────────────────────────────────────

model User {
  id             Int                                    @id @default(autoincrement())
  clerkId        String                                 @unique
  name           String
  email          String                                 @unique
  bio            String?
  avatarColor    String                                 @default("#00d4ff")
  location       Unsupported("geography(Point, 4326)")?
  createdAt      DateTime                               @default(now())
  updatedAt      DateTime                               @updatedAt

  hangouts       HangoutPost[]
  joins          HangoutJoin[]
  chatMemberships ChatMember[]
  sentMessages   Message[]

  @@index([location], name: "user_location_idx", type: Gist)
}

model HangoutPost {
  id              Int                                    @id @default(autoincrement())
  title           String
  description     String?
  category        Category
  scheduledAt     DateTime
  radiusKm        Float                                  @default(10)
  location        Unsupported("geography(Point, 4326)")?
  status          HangoutStatus                          @default(OPEN)
  maxParticipants Int                                    @default(8)
  createdAt       DateTime                               @default(now())
  updatedAt       DateTime                               @updatedAt

  userId          Int
  user            User                                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  joins           HangoutJoin[]
  chatRoom        ChatRoom?

  @@index([location], name: "hangout_location_idx", type: Gist)
  @@index([status])
  @@index([category])
}

model HangoutJoin {
  id            Int        @id @default(autoincrement())
  status        JoinStatus @default(PENDING)
  message       String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  hangoutPostId Int
  hangoutPost   HangoutPost @relation(fields: [hangoutPostId], references: [id], onDelete: Cascade)

  userId        Int
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([hangoutPostId, userId])
}

// ─── Chat ─────────────────────────────────────────────────────────────────────

model ChatRoom {
  id            Int         @id @default(autoincrement())
  // 1-to-1 with the hangout — room is created when first join is accepted
  hangoutPostId Int         @unique
  hangoutPost   HangoutPost @relation(fields: [hangoutPostId], references: [id], onDelete: Cascade)
  // Mirrors hangout scheduledAt — used by cleanup cron to expire rooms at midnight on this day
  expiresAt     DateTime
  createdAt     DateTime    @default(now())

  members       ChatMember[]
  messages      Message[]

  @@index([expiresAt])
}

model ChatMember {
  id          Int      @id @default(autoincrement())
  // Timestamp of when this user last opened the chat — used to compute unread badge
  lastReadAt  DateTime @default(now())
  joinedAt    DateTime @default(now())

  chatRoomId  Int
  chatRoom    ChatRoom @relation(fields: [chatRoomId], references: [id], onDelete: Cascade)

  userId      Int
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([chatRoomId, userId])
  @@index([userId])
}

model Message {
  id         Int      @id @default(autoincrement())
  body       String
  createdAt  DateTime @default(now())

  chatRoomId Int
  chatRoom   ChatRoom @relation(fields: [chatRoomId], references: [id], onDelete: Cascade)

  senderId   Int
  sender     User     @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([chatRoomId, createdAt])
}