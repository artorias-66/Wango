# ─── Wango Environment Variables ──────────────────────────────────────────────
# Copy this file to .env in the root and fill in the values.
# The docker-compose.yml reads from this file automatically.

# ─── Database ──────────────────────────────────────────────────────────────────
# Used only for local host-to-container access (e.g. running Prisma migrate from host)
DATABASE_URL="postgresql://postgres:your_password@localhost:5433/wango_db?schema=public"

# ─── Clerk ─────────────────────────────────────────────────────────────────────
# Get these from https://dashboard.clerk.com → Your App → API Keys
CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME
CLERK_SECRET_KEY=sk_test_REPLACE_ME
