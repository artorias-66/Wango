# Normalize all text files to LF in the repository
* text=auto eol=lf

# Force these to always be LF (cross-platform scripts)
*.sh text eol=lf
Makefile text eol=lf
Dockerfile text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
nginx.conf text eol=lf

# Windows-safe binary passthrough
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.woff binary
*.woff2 binary
